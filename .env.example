# Replicate API Key
# Get your API key from: https://replicate.com/account
# This key should be kept secret and never committed to git
REPLICATE_API_KEY=your_replicate_api_key_here

# Optional: Override the default local reference image used by Image Generator
# If not set, the app will use: /public/reference/sample-image.jpg
FLUX_REFERENCE_IMAGE_URL=
