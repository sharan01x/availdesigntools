# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# sisyphus (agent planning/build files)
.sisyphus/

# env files (keep .env.example, ignore local env)
!.env.example
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
